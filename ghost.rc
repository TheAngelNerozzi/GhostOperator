        BEGIN
            VALUE "CompanyName", "GhostOperator Open Source"
            VALUE "FileDescription", "GhostOperator (GO) - Visual Automation Agent"
            VALUE "FileVersion", "0.1.1"
            VALUE "InternalName", "ghost"
            VALUE "LegalCopyright", "Copyright (C) 2026 Angel Nerozzi"
            VALUE "OriginalFilename", "ghost.exe"
            VALUE "ProductName", "GhostOperator"
            VALUE "ProductVersion", "0.1.1"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

MAINICON ICON "ghost.ico"
